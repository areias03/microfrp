configfile: "config/config.yaml"

import os
import json
import requests
import logging as log
import polars as pl
import spirepy

ITEM_ID = config["item"]

CACHE_FILE = "results/.study_cache.json"

if os.path.exists(CACHE_FILE):
    with open(CACHE_FILE, 'r') as f:
        cache = json.load(f)
        SAMPLES = cache['samples']
        MAGS = cache['mags']
        print(f"Loaded from cache: {len(SAMPLES)} samples, {len(MAGS)} MAGs")
else:
    print("Fetching study data from API (this may take a moment)...")
    study = spirepy.Study(ITEM_ID)
    SAMPLES = [s.id for s in study.get_samples()]
    MAGS = study.get_mags()["genome_id"].to_list()
    os.makedirs("results", exist_ok=True)
    with open(CACHE_FILE, 'w') as f:
        json.dump({'samples': SAMPLES, 'mags': MAGS}, f)
    print(f"Cached study data: {len(SAMPLES)} samples, {len(MAGS)} MAGs")

print("Samples to process:", len(SAMPLES))
print("MAGs to process:", len(MAGS))

include: "rules/process_study.smk"


rule functional_roles:
    input:
        "results/manifest.csv",
	"results/reconstructions/all.done",
        # "results/.mags.cleaned",
        "results/growth_rates.csv",
        "results/exchanges.csv",
        "results/annotations.csv",
        "results/interactions.csv",
        "results/mes.csv",
        "results/models",
        "results/functional_roles.tsv",


rule simulate:
    input:
        manifest = "results/manifest.csv",
        reconstructions_done = "results/reconstructions/all.done"
    output:
        growth_rates = "results/growth_rates.csv",
        exchanges = "results/exchanges.csv",
        annotations = "results/annotations.csv",
        interactions = "results/interactions.csv",
        mes = "results/mes.csv",
        models = directory("results/models")
    resources:
            mem_mb=192000
    threads:
        24
    params:
        growth_media= config["growth_media"],
        tradeoff= config["tradeoff"]
    shell:
        "python scripts/simulation.py {input.manifest} -g {output.growth_rates} -e {output.exchanges} -a {output.annotations} -i {output.interactions} -m {output.mes} -t {threads} --models {output.models} --growth_medium {params.growth_media} --tradeoff {params.tradeoff}"

rule exchange_tendency:
    input:
        exchanges = "results/exchanges.csv",
        mes = "results/mes.csv"
    output:
        "results/exchange_tendency.csv"
    resources:
	    mem_mb=8000
    shell:
        "python scripts/exchange_tendency.py {input.exchanges} {input.mes} -o {output}"

rule cooperation_alignment:
    input:
        interactions = "results/interactions.csv",
    output:
        "results/cooperation_alignment.csv"
    resources:
            mem_mb=8000
    shell:
        "python scripts/cooperation_alignment.py {input.interactions} -o {output}"

rule provisioning_bias:
    input:
        interactions = "results/interactions.csv",
    output:
        "results/provisioning_bias.csv"
    resources:
            mem_mb=8000
    shell:
        "python scripts/provisioning_bias.py {input.interactions} -o {output}"

rule interaction_synergy:
    input:
        cooperation_alignment = "results/cooperation_alignment.csv",
        provisioning_bias = "results/provisioning_bias.csv",
    output:
        "results/interaction_synergy.csv"
    resources:
            mem_mb=8000
    shell:
        "python scripts/interaction_synergy.py -c {input.cooperation_alignment} -p {input.provisioning_bias} -o {output}"

rule combine_classifications:
    input:
        exchange_tendency = "results/exchange_tendency.csv",
        cooperation_alignment = "results/cooperation_alignment.csv",
        provisioning_bias = "results/provisioning_bias.csv",
        interaction_synergy = "results/interaction_synergy.csv",
    output:
        "results/functional_roles.tsv"
    resources:
            mem_mb=8000
    shell:
        "python scripts/combine_classifications.py {input.exchange_tendency} {input.cooperation_alignment} {input.provisioning_bias} {input.interaction_synergy} -o {output}"
