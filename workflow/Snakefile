configfile: "config/config.yaml"

import os
import requests
import logging as log
import polars as pl
import spirepy

ITEM_ID = config["item"]

study = spirepy.Study(ITEM_ID)
SAMPLES = [s.id for s in study.get_samples()]
MAGS = study.get_mags()["genome_id"].to_list()

rule functional_roles:
    input:
        "results/manifest.csv",
	"results/reconstructions/all.done",
        "results/.mags.cleaned",
        "results/growth_rates.csv",
        "results/exchanges.csv",
        "results/annotations.csv",
        "results/interactions.csv",
        "results/mes.csv",
        "results/models",
        "results/functional_roles.tsv",

checkpoint download_mags:
    output:
        mags_dir=directory("results/mags"),
        done_flag=touch("results/.mags_downloaded")
    resources:
        mem_mb=8000
    params:
        item_id=ITEM_ID
    shell:
        """
        mkdir -p {output.mags_dir}
        wget -O - https://swifter.embl.de/~fullam/spire/compiled/{params.item_id}_spire_v1_MAGs.tar | tar -xf - -C {output.mags_dir} --strip-components=1
        """

def get_mag_input(wildcards):
    # This function ensures the checkpoint is completed before accessing the file
    checkpoint_output = checkpoints.download_mags.get(**wildcards).output.mags_dir
    return os.path.join(checkpoint_output, f"{wildcards.mag}.fa.gz")

def get_reconstructions(wildcards):
    import glob
    checkpoint_output = checkpoints.download_mags.get(**wildcards).output.mags_dir
    mag_files = glob.glob(os.path.join(checkpoint_output, "*.fa.gz"))
    
    if mag_files:
        mag_ids = [os.path.basename(f).replace(".fa.gz", "") for f in mag_files]
    else:
        mag_ids = MAGS
    
    return expand("results/reconstructions/{mag}.xml", mag=mag_ids)

rule generate_sample_manifest:
    input:
        "results/reconstructions/all.done"
    output:
        temp("results/manifests/{sample}.csv"),
    resources:
            mem_mb=8000
    shell:
        "python scripts/generate_sample_manifest.py {wildcards.sample} -o {output[0]}"

rule combine_manifests:
    input:
        expand("results/manifests/{sample}.csv", sample=SAMPLES)
    output:
        "results/manifest.csv"
    resources:
            mem_mb=8000
    shell:
        "python scripts/combine_manifests.py {output} {input}"

rule reconstruct:
    input:
        get_mag_input
    output:
        "results/reconstructions/{mag}.xml"
    resources:
            mem_mb=8000
    shell:
        "carve --dna {input} -g M9 --solver cplex --output {output}"

rule reconstruct_done:
    input:
        get_reconstructions
    output:
        touch("results/reconstructions/all.done")
    resources:
            mem_mb=8000
    run:
        pass

def get_mag_files_to_cleanup(wildcards):
    import glob
    checkpoint_output = checkpoints.download_mags.get(**wildcards).output.mags_dir
    mag_files = glob.glob(os.path.join(checkpoint_output, "*.fa.gz"))
    mag_files.extend(glob.glob(os.path.join(checkpoint_output, "*.tsv")))
    
    if not mag_files:
        mag_files = [os.path.join(checkpoint_output, f"{mag}.fa.gz") for mag in MAGS]
        mag_files.extend([os.path.join(checkpoint_output, f"{mag}.tsv") for mag in MAGS])
    
    return mag_files

rule cleanup_mags:
    input:
        manifest="results/manifest.csv",
        reconstructions="results/reconstructions/all.done",
        mags=get_mag_files_to_cleanup
    output:
        touch("results/.mags.cleaned")
    resources:
	    mem_mb=8000
    run:
        import os
        for mag_file in input.mags:
            if os.path.exists(mag_file):
                os.remove(mag_file)

rule simulate:
    input:
        manifest = "results/manifest.csv",
        reconstructions_done = "results/reconstructions/all.done"
    output:
        growth_rates = "results/growth_rates.csv",
        exchanges = "results/exchanges.csv",
        annotations = "results/annotations.csv",
        interactions = "results/interactions.csv",
        mes = "results/mes.csv",
        models = directory("results/models")
    resources:
            mem_mb=192000
    threads:
        24
    params:
        growth_media= config["growth_media"],
        tradeoff= config["tradeoff"]
    threads:
        len(SAMPLES)
    shell:
        "python scripts/simulation.py {input.manifest} -g {output.growth_rates} -e {output.exchanges} -a {output.annotations} -i {output.interactions} -m {output.mes} -t {threads} --models {output.models} --growth_medium {params.growth_media} --tradeoff {params.tradeoff}"

