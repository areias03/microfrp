configfile: "config/config.yaml"

import requests
import logging as log
import polars as pl
import spirepy

ITEM_ID = config["item"]

def find_item_type(item_id):
    study_response = requests.get(f"https://spire.embl.de/spire/api/study/{item_id}")
    sample_response = requests.get(f"https://spire.embl.de/spire/api/sample/{item_id}")

    if len(study_response.content) > 3:
        return "study"
    elif len(sample_response.content) > 3:
        return "sample"
    else:
        raise ValueError(f"Item {item_id} not found on SPIRE.")


ITEM_TYPE = find_item_type(ITEM_ID)

if ITEM_TYPE == "study":
    study = spirepy.Study(ITEM_ID)
    SAMPLES = [s.id for s in study.get_samples()]
    MAGS = study.get_mags()["genome_id"].to_list()
elif ITEM_TYPE == "sample":
    SAMPLES = [ITEM_ID]
    sample = spirepy.Sample(ITEM_ID)
    MAGS = sample.get_mags()["genome_id"].to_list()
else:
    raise ValueError("Unknown item type")

print("Samples to process:", SAMPLES)
print("MAGS to process:", MAGS)

rule all:
    input:
        "results/manifest.csv",
	"results/reconstructions/all.done",
        "results/.mags.cleaned",
        "results/growth_rates.csv",
        "results/exchanges.csv",
        "results/annotations.csv",
        "results/interactions.csv",
        "results/mes.csv",
        "results/models",
	"results/functional_roles.csv",

rule download_mags:
    output:
        "results/mags/{mag}.fa.gz"
    resources:
            mem_mb=8000
    shell:
        "wget -O {output} https://spire.embl.de/download_file/{wildcards.mag}"

rule download_mags_done:
    input:
        expand("results/mags/{mag}.fa.gz", mag=MAGS)
    output:
        touch("results/mags/all.done")
    resources:
            mem_mb=8000
    run:
        pass

rule generate_sample_manifest:
    input:
        "results/mags/all.done"
    output:
        temp("results/manifests/{sample}.csv"),
    resources:
            mem_mb=8000
    shell:
        "python scripts/generate_sample_manifest.py {wildcards.sample} -o {output[0]}"

rule combine_manifests:
    input:
        expand("results/manifests/{sample}.csv", sample=SAMPLES)
    output:
        "results/manifest.csv"
    resources:
            mem_mb=8000
    shell:
        "python scripts/combine_manifests.py {output} {input}"

rule reconstruct:
    input:
        "results/mags/{mag}.fa.gz"
    output:
        "results/reconstructions/{mag}.xml"
    resources:
            mem_mb=8000
    shell:
        "carve --dna {input} -g M9 --solver cplex --output {output}"

rule reconstruct_done:
    input:
        expand("results/reconstructions/{mag}.xml", mag=MAGS)
    output:
        touch("results/reconstructions/all.done")
    resources:
            mem_mb=8000
    run:
        pass

rule cleanup_mags:
    input:
        "results/manifest.csv",
        "results/reconstructions/all.done"
    output:
        touch("results/.mags.cleaned")
    resources:
	    mem_mb=8000
    run:
        import os
	import shutil
        for mag in MAGS:
            p = f"results/mags/{mag}.fa.gz"
            if os.path.exists(p):
                os.remove(p)
            p = f"results/mags/{mag}.tsv"
            if os.path.exists(p):
                os.remove(p)

rule simulate:
    input:
        manifest = "results/manifest.csv",
        reconstructions_done = "results/reconstructions/all.done"
    output:
        growth_rates = "results/growth_rates.csv",
        exchanges = "results/exchanges.csv",
        annotations = "results/annotations.csv",
        interactions = "results/interactions.csv",
        mes = "results/mes.csv",
        models = directory("results/models")
    resources:
	    mem_mb=192000
    params:
        growth_media= config["growth_media"],
        tradeoff= config["tradeoff"]
    threads:
        len(SAMPLES)
    shell:
        "python scripts/simulation.py {input.manifest} -g {output.growth_rates} -e {output.exchanges} -a {output.annotations} -i {output.interactions} -m {output.mes} -t {threads} --models {output.models} --growth_medium {params.growth_media} --tradeoff {params.tradeoff}"

rule uptake_tendency:
    input:
        exchanges = "results/exchanges.csv",
        mes = "results/mes.csv"
    output:
        "results/uptake_tendency.csv"
    resources:
	    mem_mb=8000
    shell:
        "python scripts/uptake_tendency.py {input.exchanges} {input.mes} -o {output}"

rule cooperation_alignment:
